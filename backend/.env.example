APP_NAME=Mekong-SALT Backend
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Neon URLs from the dashboard usually start with postgresql:// and include
# sslmode/channel_binding. The app normalizes them to asyncpg at runtime.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

REDIS_URL=redis://localhost:6379/0
EXTERNAL_CONTEXT_CACHE_TTL_SECONDS=600
WEATHER_SNAPSHOT_FRESHNESS_MINUTES=30
RISK_RULE_VERSION=v1
OPEN_METEO_WEATHER_BASE_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_MARINE_BASE_URL=https://marine-api.open-meteo.com/v1/marine

LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
LLM_TEMPERATURE=0.2
LLM_REQUEST_TIMEOUT_SECONDS=30

# Reactive active monitoring is the default runtime path.
ACTIVE_MONITORING_ENABLED=true
ACTIVE_MONITORING_MODE=active
ACTIVE_MONITORING_POLL_SECONDS=30
ACTIVE_MONITORING_LOCK_TTL_SECONDS=300
ACTIVE_MONITORING_BATCH_SIZE=50
REACTIVE_AUTO_APPROVE_ENABLED=true
REACTIVE_AUTO_EXECUTE_ENABLED=true
