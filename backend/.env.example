APP_NAME=Mekong-SALT Backend
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mekong_salt
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

REDIS_URL=redis://localhost:6379/0
EXTERNAL_CONTEXT_CACHE_TTL_SECONDS=600
WEATHER_SNAPSHOT_FRESHNESS_MINUTES=30
RISK_RULE_VERSION=v1
OPEN_METEO_WEATHER_BASE_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_MARINE_BASE_URL=https://marine-api.open-meteo.com/v1/marine

LLM_PROVIDER=gemini
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
