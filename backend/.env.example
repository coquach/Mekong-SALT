APP_NAME=Mekong-SALT Backend
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Neon URLs from the dashboard usually start with postgresql:// and include
# sslmode/channel_binding. The app normalizes them to asyncpg at runtime.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

REDIS_URL=redis://localhost:6379/0
EXTERNAL_CONTEXT_CACHE_TTL_SECONDS=600
WEATHER_SNAPSHOT_FRESHNESS_MINUTES=30
RISK_RULE_VERSION=v1
OPEN_METEO_WEATHER_BASE_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_MARINE_BASE_URL=https://marine-api.open-meteo.com/v1/marine
IOT_INGEST_MODE=http

MQTT_ENABLED=false
MQTT_BROKER_URL=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=mekong-salt-backend
MQTT_TOPIC_SENSOR_READINGS=mekong/sensors/readings
MQTT_TOPIC_DEVICE_STATUS=mekong/sensors/status
MQTT_TOPIC_DEAD_LETTER=mekong/sensors/readings/dlq
MQTT_QOS=1

IOT_DLQ_ARCHIVE_ENABLED=true
IOT_DLQ_ARCHIVE_PATH=artifacts/ingest_dlq_archive.jsonl

PUBSUB_ENABLED=false
PUBSUB_PROJECT_ID=
PUBSUB_SUBSCRIPTION_SENSOR_READINGS=
PUBSUB_TOPIC_SENSOR_EVENTS=
PUBSUB_DEAD_LETTER_TOPIC=
PUBSUB_EMULATOR_HOST=
PUBSUB_MAX_DELIVERY_ATTEMPTS=5
PUBSUB_FLOW_MAX_MESSAGES=100

EARTH_ENGINE_ENABLED=false
EARTH_ENGINE_PROJECT_ID=
EARTH_ENGINE_SERVICE_ACCOUNT_EMAIL=
EARTH_ENGINE_SERVICE_ACCOUNT_KEY_PATH=
EARTH_ENGINE_DEFAULT_DATASET=COPERNICUS/S2_SR_HARMONIZED
EARTH_ENGINE_REGION_BUFFER_M=3000

LLM_PROVIDER=gemini
LLM_USE_VERTEX=true
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=us-central1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
RAG_USE_VERTEX_VECTOR_SEARCH=true
RAG_ENABLE_LOCAL_FALLBACK=true
RAG_STATIC_CORPUS_PROVIDER=vector_search
RAG_EMBEDDING_MODEL=text-embedding-005
RAG_RETRIEVAL_TOP_K=8
RAG_CSV_REINDEX_TTL_DAYS=7
VERTEX_VECTOR_SEARCH_INDEX=
VERTEX_VECTOR_SEARCH_INDEX_ENDPOINT=
VERTEX_VECTOR_SEARCH_DEPLOYED_INDEX_ID=
LLM_TEMPERATURE=0.2
LLM_REQUEST_TIMEOUT_SECONDS=30

# Lifecycle graph active monitoring runtime settings.
ACTIVE_MONITORING_ENABLED=true
ACTIVE_MONITORING_MODE=active
ACTIVE_MONITORING_POLL_SECONDS=30
ACTIVE_MONITORING_LOCK_TTL_SECONDS=300
ACTIVE_MONITORING_BATCH_SIZE=50
ACTIVE_MONITORING_APPROVAL_TIMEOUT_MINUTES=60
ACTIVE_MONITORING_APPROVAL_TIMEOUT_ACTION=auto_reject
ACTIVE_MONITORING_FEEDBACK_REPLAN_MAX_ATTEMPTS=1
REACTIVE_AUTO_APPROVE_ENABLED=true
REACTIVE_AUTO_EXECUTE_ENABLED=true
